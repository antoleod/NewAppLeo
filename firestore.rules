rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSixDigitCode(code) {
      return code.matches('^[0-9]{6}$');
    }

    // Allows a user to create a non-owner session on a host's path
    // when a valid pairing session exists linking them.
    function isPairedMember(hostUid) {
      let code = request.resource.data.get('pairingCode', '');
      return code != ''
        && isSixDigitCode(code)
        && !request.resource.data.get('isOwner', false)
        && exists(/databases/$(database)/documents/pairingSessions/$(code))
        && get(/databases/$(database)/documents/pairingSessions/$(code)).data.hostUid == hostUid
        && request.auth.uid in get(/databases/$(database)/documents/pairingSessions/$(code)).data.memberUids;
    }

    match /usernames/{username} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /emails/{email} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /pairingSessions/{code} {
      allow get, list: if isSignedIn()
        && isSixDigitCode(code)
        && request.auth.uid in resource.data.memberUids;

      allow create: if isSignedIn()
        && isSixDigitCode(code)
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.memberUids.size() == 1
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.status == 'pending';

      allow update: if isSignedIn()
        && isSixDigitCode(code)
        && request.resource.data.hostUid == resource.data.hostUid
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.status in ['pending', 'paired'];

      allow delete: if false;
    }

    match /users/{uid} {
      allow read, create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;

      match /entries/{entryId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }

      match /sessions/{sessionId} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow create: if isSignedIn() && (
          request.auth.uid == uid
          || isPairedMember(uid)
        );
        allow update: if isSignedIn() && request.auth.uid == uid;
        allow delete: if isSignedIn() && request.auth.uid == uid && resource.data.isOwner != true;
      }
    }
  }
}
