{
  "expo": {
    "name": "BabyFlow",
    "slug": "appleo",
    "scheme": "appleo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/app-icon/babyflow-app-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "baseUrl": "/NewAppLeo/"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./public/favicon.png"
    },
    "ios": {
      "bundleIdentifier": "com.appleo.babytracker",
      "buildNumber": "1",
      "icon": "./assets/branding/app-icon/babyflow-app-icon-1024.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to unlock App Leo",
        "NSCameraUsageDescription": "Used to add photos to entries"
      }
    },
    "android": {
      "package": "com.appleo.babytracker",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app-icon/babyflow-app-icon-512.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-localization",
      "expo-secure-store",
      "expo-local-authentication"
    ]
  }
}

