{
  "expo": {
    "name": "App Leo",
    "slug": "appleo",
    "scheme": "appleo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/app-icon/babyflow-app-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "baseUrl": "/NewAppLeo/"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/branding/app-icon/babyflow-app-icon-192.png",
      "manifest": {
        "name": "App Leo",
        "short_name": "App Leo",
        "start_url": ".",
        "display": "standalone",
        "background_color": "#ffffff",
        "theme_color": "#ffffff",
        "scope": ".",
        "description": "App Leo - cuidado y seguimiento para bebés desde la web o PWA.",
        "icons": [
          {
            "src": "./assets/branding/app-icon/babyflow-app-icon-192.png",
            "sizes": "192x192",
            "type": "image/png"
          },
          {
            "src": "./assets/branding/app-icon/babyflow-app-icon-512.png",
            "sizes": "512x512",
            "type": "image/png"
          }
        ]
      }
    },
    "ios": {
      "icon": "./assets/branding/app-icon/babyflow-app-icon-1024.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app-icon/babyflow-app-icon-512.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-localization",
      "expo-secure-store"
    ]
  }
}
