{
  "expo": {
    "name": "App Leo",
    "slug": "appleo",
    "scheme": "appleo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/app-icon/babyflow-app-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "baseUrl": "/NewAppLeo/"
    },
    "web": {
      "bundler": "metro",
      "template": "./index.html",
      "favicon": "./public/favicon.png",
      "manifest": {
        "name": "App Leo",
        "short_name": "App Leo",
        "start_url": "/NewAppLeo/",
        "display": "standalone",
        "orientation": "portrait",
        "background_color": "#0D1117",
        "theme_color": "#0D1117",
        "scope": "/NewAppLeo/",
        "description": "App Leo - baby care and tracking. Daily logs for feeding, sleep, diapers and more.",
        "categories": ["health", "medical", "lifestyle"],
        "icons": [
          {
            "src": "icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
          },
          {
            "src": "icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
          },
          {
            "src": "icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
          },
          {
            "src": "icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
          }
        ]
      }
    },
    "ios": {
      "bundleIdentifier": "com.appleo.babytracker",
      "buildNumber": "1",
      "icon": "./assets/branding/app-icon/babyflow-app-icon-1024.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to unlock App Leo",
        "NSCameraUsageDescription": "Used to add photos to entries"
      }
    },
    "android": {
      "package": "com.appleo.babytracker",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app-icon/babyflow-app-icon-512.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-localization",
      "expo-secure-store",
      "expo-local-authentication"
    ]
  }
}

