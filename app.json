{
  "expo": {
    "name": "App Leo",
    "slug": "appleo",
    "scheme": "appleo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/app-icon/babyflow-app-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "baseUrl": "/NewAppLeo/"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./public/favicon.ico",
      "manifest": {
        "name": "App Leo",
        "short_name": "App Leo",
        "start_url": "/NewAppLeo/",
        "display": "standalone",
        "orientation": "portrait",
        "background_color": "#0D1117",
        "theme_color": "#0D1117",
        "scope": "/NewAppLeo/",
        "description": "App Leo — baby care & tracking. Daily logs for feeding, sleep, diapers and more.",
        "categories": ["health", "medical", "lifestyle"],
        "icons": [
          {
            "src": "/NewAppLeo/icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
          },
          {
            "src": "/NewAppLeo/icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
          },
          {
            "src": "/NewAppLeo/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
          },
          {
            "src": "/NewAppLeo/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
          }
        ]
      }
    },
    "ios": {
      "icon": "./assets/branding/app-icon/babyflow-app-icon-1024.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app-icon/babyflow-app-icon-512.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-localization",
      "expo-secure-store"
    ]
  }
}
